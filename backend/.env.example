PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/8track?retryWrites=true&w=majority
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Generate VAPID keys by running: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com



# SMTP (Nodemailer - Gmail App Password)
SMTP_USER=..................
SMTP_PASS=..........................
OTP_EXPIRES_MINUTES=.....


# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/callback
# Separate redirect URI for Google Login (must be registered in Cloud Console too)
GOOGLE_OAUTH_LOGIN_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Timezone for Google Calendar events (e.g. Asia/Kolkata, America/New_York)
TIMEZONE=Asia/Kolkata
