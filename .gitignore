# Root-level gitignore for 8Track monorepo

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/

# Environment files — NEVER commit these
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# Test files
test-*.js

# TypeScript leftovers (we switched to JS)
*.ts
tsconfig.json
